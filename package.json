{
  "name": "high-vive-benchmark-league",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "test:unit": "node --test tests/protocol.test.mjs",
    "test:property": "node --test tests/protocol-property.test.mjs",
    "test:integration": "node --test tests/api-contract.test.mjs",
    "test:security": "node --test tests/security-contract.test.mjs",
    "test:history": "node --test tests/history-scan.test.mjs",
    "test:migration": "node --test tests/migration.test.mjs",
    "test:e2e": "vinext build && node --test tests/rendered-html.test.mjs",
    "passport:scan": "node tools/high-vive-history-scan.mjs",
    "high-vive": "node packages/cli/src/index.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
